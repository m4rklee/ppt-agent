# PPTAgent 本地运行配置（复制为 .env 并填入真实值）
# cp .env.example .env

# OpenAI 兼容 API（示例：SiliconFlow / AiHubMix / DeepSeek 等）
OPENAI_API_KEY=your-api-key-here
API_BASE=https://aihubmix.com/v1

# 语言模型（负责大纲/内容生成）
LANGUAGE_MODEL=deepseek-v4-flash

# 视觉模型（需支持 vision，用于幻灯片布局分析）
VISION_MODEL=gpt-4o-mini

# 文本嵌入模型
TEXT_MODEL=text-embedding-3-small
